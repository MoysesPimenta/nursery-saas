{
  "root": true,
  "extends": ["eslint:recommended"],
  "env": { "node": true, "es2024": true },
  "ignorePatterns": ["node_modules", "dist", ".next", "coverage"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx"],
      "parser": "@typescript-eslint/parser",
      "extends": ["eslint:recommended"]
    },
    {
      "files": ["**/__tests__/**/*.ts", "**/__tests__/**/*.tsx", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
      "env": { "jest": true }
    }
  ]
}
